	public static void reverseStr(char [] ch) {
		
		int s =0;
		int len =ch.length-1;
		
		while(s<=len) {
			char temp = ch[s];
			ch[s] =ch[len];
			ch[len] =temp;
			s++;
			len--;
		}
		
	}

}
