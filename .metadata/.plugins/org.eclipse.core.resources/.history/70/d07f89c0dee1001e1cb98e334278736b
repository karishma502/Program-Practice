	public static boolean isPalidrome(String s) {
		
		s=s.toLowerCase().replaceAll("[^a-ZA-Z0-9]", "");
		int i=0;
		int j= s.length()-1;
		
		while(i<=j) {
			if(s.charAt(i) != s.charAt(j)) {
				return false;
			}
			i++;
			j--;
		}
		return true;
		
	}

}
